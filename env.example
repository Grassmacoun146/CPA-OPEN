# ==========================================
# 🌌 [公共区域] 核心账号与注册策略
# ==========================================
# 运行模式: 0=本机模式(带界面), 1=VPS服务器模式(纯命令行交互)
RUN_MODE=0

# CPA 上传接口配置 (无论本机还是VPS，只要开启就会上传)
# 方案 A (分布式部署): 注册机与CPA不在一起。开启该项后，将通过网络将凭据同步到远端 CPA 系统。
# 方案 B (同机部署): 注册机与CPA在同一VPS。CPA 会直接读取 credentials 文件夹中的内容，此时请保持 CPA_UPLOAD_ENABLED=0 并确保 TOKEN_OUTPUT_DIR 指向正确。
CPA_UPLOAD_ENABLED=0
CPA_API_URL=https://cpa.yourdomain.com/v0/management/auth-files
CPA_API_TOKEN=123456
# CPA 上传独立走代理 (0:直连[推荐], 1:走代理)
# 重要：若您的 CPA 后端就在此 VPS 上，请务必设为 0 以防止代理网络回环导致的 521/Connection Reset 报错。
CPA_USE_PROXY=0

# 邮箱 IMAP 验证配置 (抓取验证码必需)
IMAP_USER=example@gmail.com
IMAP_PASS=abcd efgh ijkl mnop
IMAP_SERVER=imap.gmail.com

# 裂变主邮箱列表 (多个邮箱请用逗号隔开)
# 如果所有邮箱共用上述 IMAP 密码，则不需要填写密码
EMAIL_LIST=master1@gmail.com, master2@gmail.com, master3@domain.com
# 裂变标签长度 (默认8位, 如: +abcde123@xxx.com)
TAG_LENGTH=8

# 成功凭据保存本地的目录名
TOKEN_OUTPUT_DIR=credentials

# ==========================================
# 🖥️ [本机配置] 注册任务与网络环境
# ==========================================
# 网络代理 (本机运行建议开启，支持 http/socks5)
# 若在国外 VPS 运行且不需要代理，请设 PROXY_ENABLED=0
PROXY=http://127.0.0.1:10808
PROXY_ENABLED=1

# 任务控制
# 并发线程数
THREAD_COUNT=1
# 累计成功注册多少个账号后自动停止任务
TARGET_SUCCESS_COUNT=100


# ==========================================
# 🚀 [VPS 配置] 自动化巡检与仓库补货
# ==========================================
# 仓库巡检引擎开关 (仅在 RUN_MODE=1 时生效)
CPA_MAINTENANCE_ENABLED=1
# 仓库最低库存量 (当存量低于此值时，巡检引擎将自动启动补货任务)
MIN_ACCOUNTS_THRESHOLD=15
# 巡检仓库的时间间隔 (单位: 分钟)
CHECK_INTERVAL_MINUTES=30
# 注册冷却周期 (单位: 小时, 避免对同一主邮箱短时间频繁注册)
COOL_DOWN_HOURS=24
# 巡检时是否物理删除失效/死号
CPA_CLEAN_DEAD=1
